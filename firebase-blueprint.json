{
  "entities": {
    "userProfile": {
      "title": "User Profile",
      "description": "Stores user investment configuration and preference.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The Firebase Auth UID of the user." },
        "currentCorpus": { "type": "number", "description": "Current principal amount." },
        "targetCorpus": { "type": "number", "description": "Target future corpus." },
        "years": { "type": "number", "description": "Investment duration in years." },
        "riskLevel": { "type": "number", "description": "Risk profile score 1-10." },
        "inflationRate": { "type": "number", "description": "Assumption for yearly inflation." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last modified timestamp." }
      },
      "required": ["userId", "currentCorpus", "targetCorpus", "years", "riskLevel", "inflationRate", "updatedAt"]
    },
    "marketFeed": {
      "title": "Market Feed Cache",
      "description": "Caches the latest refined ROI data from Gemini grounding.",
      "type": "object",
      "properties": {
        "assetClasses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "roi": { "type": "number" },
              "riskScore": { "type": "number" },
              "ticker": { "type": "string" },
              "price": { "type": "string" },
              "color": { "type": "string" }
            }
          }
        },
        "fetchedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["assetClasses", "fetchedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "userProfile",
      "description": "Individual user wealth configuration."
    },
    "/market/latest": {
      "schema": "marketFeed",
      "description": "Global cache for the latest market grounding results."
    }
  }
}
